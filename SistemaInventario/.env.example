# Ejemplo de variables de entorno. Copia este archivo a .env y rellena los valores reales.
# Las claves deben coincidir con las usadas en application.properties.

# --- DataSource (Aiven MySQL) ---
DB_URL=jdbc:mysql://HOST:PORT/DBNAME?ssl-mode=REQUIRED
DB_USERNAME=usuario
DB_PASSWORD=contraseña

# --- JPA ---
JPA_DDL_AUTO=update
JPA_DIALECT=org.hibernate.dialect.MySQLDialect
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

# --- JWT (HS256) ---
# Minimo 32 bytes. Generar uno seguro con: openssl rand -base64 48
JWT_SECRET=replace-with-secure-random-secret
JWT_EXPIRATION_MS=3600000

# --- Imgur (hosting de imagenes de productos) ---
# Obtene tu Client ID en https://api.imgur.com/oauth2/addclient
# Elegi "OAuth 2 authorization without callback" (uploads anonimos)
IMGUR_CLIENT_ID=your-imgur-client-id